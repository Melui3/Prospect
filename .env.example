# ── Django ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
OWNER_ACCESS_TOKEN=change-me-to-a-long-private-token

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=prospect_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Email SMTP ────────────────────────────────────────────────
# Gmail : créez un "App Password" dans votre compte Google
# (Sécurité → Authentification 2 facteurs → Mots de passe d'application)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre_app_password
DEFAULT_FROM_EMAIL=votre@gmail.com

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Scraping
OVERPASS_ENDPOINTS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
OVERPASS_TIMEOUT=25
PAGES_JAUNES_MAX_LOOKUPS=10
PAGES_JAUNES_TIMEOUT=3
PAGES_JAUNES_DELAY_SECONDS=0.2
